            briefs.forEach((b, idx) => {
                const btn = document.createElement('button');
                btn.className = `px-6 py-2 rounded-full font-bold transition-all duration-200 uppercase text-[10px] tracking-widest shadow-sm ${idx === activeIdx ? 'tab-active' : 'bg-white text-slate-400 hover:bg-gray-200'}`;
                btn.textContent = b.brand;
                btn.onclick = () => {
                    activeIdx = idx;
                    updateUI();
                };
                container.appendChild(btn);
            });
        }

        // Init
        updateUI();
    </script>
</body>
</html>
